{
  "name": "manse",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, browser-native motion gaming platform and Codex publishing toolkit",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pretypecheck": "npm run build --workspace @manse/schema",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "validate": "npm run typecheck && npm run test && npm run build",
    "showcase:dev": "npm run dev --workspace @manse/showcase",
    "showcase:build": "npm run build --workspace @manse/showcase"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
