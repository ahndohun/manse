{
  "name": "@manse/schema",
  "version": "0.1.0",
  "description": "Versioned public contracts and validators for the Manse platform",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./json-schema/*": "./json-schema/*",
    "./fixtures/*": "./fixtures/*"
  },
  "files": ["dist", "fixtures", "json-schema", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "schema:generate": "tsx scripts/export-json-schema.ts",
    "validate": "npm run typecheck && npm run test && npm run schema:generate && npm run build"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "zod-to-json-schema": "3.25.0"
  }
}
