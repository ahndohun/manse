{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://manse.dev/schema/catalog-v1.schema.json",
  "$comment": "Runtime parsing also enforces unique manifest URLs.",
  "$ref": "#/definitions/ManseCatalogV1",
  "definitions": {
    "ManseCatalogV1": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "games": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "manifestUrl": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "manifestUrl"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schemaVersion",
        "games"
      ],
      "additionalProperties": false
    }
  }
}
