                              "timeBudgetMs": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/challenge/anyOf/0/anyOf/0/properties/timeBudgetMs"
                              },
                              "successAudioId": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/id"
                              },
                              "encourageAudioId": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/id"
                              }
                            },
                            "required": [
                              "type",
                              "durationMs",
                              "intensity",
                              "timeBudgetMs",
                              "successAudioId",
                              "encourageAudioId"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "balance"
                              },
                              "pose": {
                                "type": "string",
                                "enum": [
                                  "one-leg",
                                  "airplane",
                                  "tiptoe",
                                  "statue"
                                ]
                              },
                              "holdMs": {
                                "type": "integer",
                                "minimum": 500,
                                "maximum": 6000
                              },
                              "timeBudgetMs": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/challenge/anyOf/0/anyOf/0/properties/timeBudgetMs"
                              },
                              "successAudioId": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/id"
                              },
                              "encourageAudioId": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/id"
                              }
