            "engine": {
              "type": "object",
              "properties": {
                "minimumVersion": {
                  "type": "string",
                  "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
                },
                "maximumVersion": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/engine/properties/minimumVersion"
