            "maxStruggleStreak": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "maxHighEnergyMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 180000
            }
          },
          "required": [
            "targetSuccessBand",
            "maxStruggleStreak",
            "maxHighEnergyMs"
          ],
          "additionalProperties": false
        },
