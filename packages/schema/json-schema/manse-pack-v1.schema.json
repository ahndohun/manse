                      "maxLength": 200
                    },
                    "reasoningEffort": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 100
                    },
                    "generatedAt": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": [
                    "model",
                    "reasoningEffort",
                    "generatedAt"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "id",
            "title",
            "summary",
            "theme",
            "locales",
            "ageBands",
            "estMinutes",
            "engine",
