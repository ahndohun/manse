                "required": [
                  "id",
                  "kind",
                  "narration",
                  "demo",
                  "challenge",
                  "learning",
                  "artAssetId",
                  "energy",
                  "terminal",
                  "transitions"
                ],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 3
