                    "type": "string",
                    "minLength": 1,
                    "maxLength": 300
                  },
                  "mediaType": {
                    "type": "string",
                    "enum": [
                      "image/png",
                      "image/jpeg",
                      "image/webp",
                      "image/avif"
                    ]
