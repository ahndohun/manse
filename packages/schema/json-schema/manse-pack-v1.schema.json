                              "targetScale": {
                                "type": "number",
                                "minimum": 0.5,
                                "maximum": 2
                              },
                              "dwellMs": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 1500
                              },
                              "limb": {
                                "type": "string",
                                "enum": [
                                  "hands",
                                  "feet",
                                  "any"
                                ]
                              },
                              "timeBudgetMs": {
