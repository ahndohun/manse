                    "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/narration"
                  },
                  "demo": {
                    "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/demo"
                  },
                  "challenge": {
                    "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/challenge"
                  },
                  "learning": {
                    "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/learning"
                  },
                  "artAssetId": {
                    "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/artAssetId"
                  },
                  "energy": {
                    "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/energy"
                  },
                  "terminal": {
                    "type": "boolean",
                    "const": true
