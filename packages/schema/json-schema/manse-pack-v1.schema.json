                              "reps": {
                                "type": "integer",
                                "minimum": 1,
                                "maximum": 15
                              },
                              "timeBudgetMs": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/scenes/items/anyOf/0/properties/challenge/anyOf/0/anyOf/0/properties/timeBudgetMs"
                              },
                              "successAudioId": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/id"
                              },
                              "encourageAudioId": {
                                "$ref": "#/definitions/ManseEpisodePackV1/properties/meta/properties/id"
                              }
