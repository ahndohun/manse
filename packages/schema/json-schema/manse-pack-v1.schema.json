                  "locale": {
                    "type": "string",
                    "enum": [
                      "en",
                      "ko",
                      "es",
                      "ja",
                      "zh",
                      "fr",
                      "de",
                      "ar"
                    ]
                  },
                  "text": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 5000
                  }
                },
                "required": [
                  "locale",
                  "text"
