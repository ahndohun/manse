  "$id": "https://manse.dev/schema/manse-pack-v1.schema.json",
  "$comment": "Use @manse/schema at runtime for graph, reference, locale, and terminal-reachability checks.",
  "$ref": "#/definitions/ManseEpisodePackV1",
  "definitions": {
    "ManseEpisodePackV1": {
      "type": "object",
