{
  "name": "@manse/runtime-web",
  "version": "0.1.0",
  "description": "Framework-neutral browser player for Manse motion games",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@manse/schema": "0.1.0",
    "@mediapipe/tasks-vision": "0.10.35"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
