{
  "name": "@manse/cli",
  "version": "0.1.0",
  "description": "Safe local tooling for validating, packaging, and listing Manse games",
  "license": "MIT",
  "type": "module",
  "bin": {
    "manse": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@manse/schema": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
